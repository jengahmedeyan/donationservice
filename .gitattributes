# Standardize on LF in the repo and working tree, cross-platform. This must match
# .editorconfig's `end_of_line = lf`, or `dotnet format` fails on the Linux CI runner.
* text=auto eol=lf

# Source and config files: always LF.
*.cs text eol=lf
*.csproj text eol=lf
*.props text eol=lf
*.json text eol=lf
*.md text eol=lf
*.sh text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
